class ProductOfNumbers {
public:
    vector<int>arr;
    ProductOfNumbers() {
        arr={1};
    }
    
    void add(int num) {
        if(num==0)
        {
            arr={1};    //reset to 1
            
        }
        else
        {
            int product=arr[arr.size()-1]*num;
            arr.push_back(product);
        }
    }
    
    int getProduct(int k) {
        if(k>=arr.size())
            return 0;
        return arr[arr.size()-1]/arr[arr.size()-1-k];
    }
};

