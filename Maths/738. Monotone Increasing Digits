class Solution {
public:
    int monotoneIncreasingDigits(int n) {
        string s=to_string(n);
        int m=s.size();
        int index=m;

        //move right to left and check if [i-1]>[i] 
        // if yes decrement [i-1] and store index [i] so that we later make all after it as 9 
        for(int i=m-1;i>=1;i--)
        {
            if(s[i-1]>s[i])
            {
                s[i-1]--;
                index=i;
            }
        }
        //now make all elements after including index as 9
        for(int i=index;i<m;i++)
        {
            s[i]='9';
        }
        return stoi(s);
    }
};
