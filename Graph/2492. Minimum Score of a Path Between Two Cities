class Solution {
public:
    void DFS(int node,vector<vector<pair<int,int>>>& adj,vector<bool>& visited,int& mini)
    {
        visited[node]=1;

        for(int j=0;j<adj[node].size();j++)
        {
            mini=min(mini,adj[node][j].second);
            if(!visited[adj[node][j].first])
            {   
                DFS(adj[node][j].first,adj,visited,mini);
            }
        }

    }
    int minScore(int n, vector<vector<int>>& roads) {
        vector<vector<pair<int,int>>> adj(n);
        for(int i=0;i<roads.size();i++)
        {
            int u=roads[i][0]-1;
            int v=roads[i][1]-1;
            int w=roads[i][2];

            adj[u].push_back({v,w});
            adj[v].push_back({u,w});
        }
        vector<bool>visited(n,0);
        int mini=INT_MAX;
       DFS(0,adj,visited,mini);
       return mini;
        
    }
};
