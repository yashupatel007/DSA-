class DSU{
    public:

    vector<int>parent;
    vector<int>size;

    DSU(int n)
    {
        parent.resize(n);
        size.resize(n,1);

        //make own as the parent
        for(int i=0;i<n;i++)
        {
            parent[i]=i;
        }
    }

    // find fn
    int find(int node)
    {
        //base case
        if(node==parent[node])// ultimate parent
            return node;
        
        return parent[node]=find(parent[node]); // make parent changes in jaha se aaye ho
    }

    void unionBySize(int u,int v)
    {
        int rootU=find(u);
        int rootV=find(v);

        if(rootU==rootV)// base case
            return;
        
        //merge the smaller one to the big one
        if(size[rootU]>size[rootV])
        {
            parent[rootV]=rootU;
            size[rootU]+=size[rootV];
        }
        else
        {
            parent[rootU]=rootV;
            size[rootV]+=size[rootU];
        }
    }     
};

class Solution {
public:

    vector<bool> pathExistenceQueries(int n, vector<int>& nums, int maxDiff, vector<vector<int>>& queries) {
        int m=queries.size();
        vector<bool>ans(m,false);
        DSU dsu(n);
        // check the maxDiff condition and use DSU to make edge
        for(int i=0;i<nums.size()-1;i++)
        {
            if(nums[i+1]-nums[i]<=maxDiff)
            {
                dsu.unionBySize(i,i+1);
            }
        }

        for(int i=0;i<m;i++)
        {
            int start=queries[i][0];
            int end=queries[i][1];

            if(dsu.find(start)==dsu.find(end))
                ans[i]=true;
        }
        return ans;
    }
};
