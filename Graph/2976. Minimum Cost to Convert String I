link - https://leetcode.com/problems/minimum-cost-to-convert-string-i/description/
TC- O(V^3 + N) =O(N), V=26 , N= length of source string
SC- O(V^2) = O(1) , v=26
code-

class Solution {
public:
    long long minimumCost(string source, string target, vector<char>& original, vector<char>& changed, vector<int>& cost) {
        vector<vector<int>>mat(26,vector<int>(26,INT_MAX));
        for(int i=0;i<original.size();i++)  //update the cost in mat
        {
            
            mat[original[i]-'a'][changed[i]-'a']=min(mat[original[i]-'a'][changed[i]-'a'],cost[i]);  //store min for parallell values
        }

        //use floyd  warshal to find the multisource shortest path dist
        for(int k=0;k<26;k++)
        {
            for(int i=0;i<26;i++)
            {
                for(int j=0;j<26;j++)
                {
                    if(mat[i][k]==INT_MAX || mat[k][j]==INT_MAX)
                        continue;

                    mat[i][j]=min(mat[i][j],mat[i][k]+mat[k][j]);
                }
            }
        }
        //traverse source & target & calculate total cost
        long long totalCost=0;
        for(int i=0;i<source.size();i++)
        {
            mat[source[i]-'a'][source[i]-'a']=0; // 1->1 , dist=0
            
            if(mat[source[i]-'a'][target[i]-'a']==INT_MAX)
                return -1;

            totalCost+=mat[source[i]-'a'][target[i]-'a'];
        }
        return totalCost;
    }
};
