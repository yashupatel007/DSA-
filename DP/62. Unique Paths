class Solution {
public:
    int uniquePaths(int m, int n) {
        int totalDown=m-1;
        int totalRight=n-1;
        
        int step=min(totalDown,totalRight);
        int totalSum=totalDown+totalRight+1;
        long long prevProduct=1;
        for(int i=1;i<=step;i++)
        {
            totalSum--;
            prevProduct=prevProduct*(totalSum);
            prevProduct/=i;
        }
        return prevProduct;
    }
};
