class Solution {
public:
    long long rob(vector<int>& nums, vector<int>& colors) {
        int n=nums.size();
        if(n==1)    return nums[0];
        
        long long second=nums[0];
        long long first;
        if(colors[0]==colors[1])
            first=max(nums[0],nums[1]);
        else
            first=nums[0]+nums[1];
        
        if(n==2)    return first;

        long long maxi=0;
        for(int i=2;i<n;i++)
        {
            if(colors[i]==colors[i-1])
            {
                maxi=max(nums[i]+second,first);
                second=first;
                first=maxi;
            }
            else
            {
                maxi=max(nums[i]+first,nums[i]+second);
                second=first;
                first=maxi;
            }
            
        }
        return maxi;
    }
};
