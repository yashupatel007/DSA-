class Solution {
public:
    void nextPermutation(vector<int>& nums) {
        int n=nums.size();
        // find the pivot (element smaller than its right)

        int pivot=-1;
        for(int i=n-2;i>=0;i--)
        {
            if(nums[i]<nums[i+1])
            {
                pivot=i;
                break;
            }
        }
        if(pivot==-1)
        {
            reverse(nums.begin(),nums.end());
            return;
        }

        //swap the pivot from the right greatest than it
        int greaterIndex=-1;
        for(int i=n-1;i>=0;i--)
        {
            if(nums[i]>nums[pivot])
            {
                greaterIndex=i;
                break;
            }
        }
        swap(nums[greaterIndex],nums[pivot]);
        // reverse the remaining vector after the pivot 
        reverse(nums.begin()+pivot+1,nums.end());
    }
};
