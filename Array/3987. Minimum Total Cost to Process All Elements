class Solution {
public:
    long long MOD=1e9+7;
    int minimumCost(vector<int>& nums, int k) {
        int n=nums.size();
     long long totalOp=0;
        long long available=k;
        for(int i=0;i<n;i++)
            {
                if(available<nums[i])
                {
                    long long less=nums[i]-available;
                    long long op=(less+k-1)/k;
                    totalOp+=op;
                    available+=op*k;
                }
                available-=nums[i];
            }
        long long ans=0;
        if(totalOp%2==0)
            ans=((totalOp/2)%MOD)*((totalOp+1)%MOD)%MOD;
        else
            ans=((totalOp)%MOD)*(((totalOp+1)/2)%MOD)%MOD;

        return ans;
    }
};
