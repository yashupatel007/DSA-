class Solution {
public:
    vector<int> arrayRankTransform(vector<int>& arr) {
        int n=arr.size();
        vector<pair<int,int>>nums(n,{0,0});

        for(int i=0;i<n;i++)
        {
            nums[i]={arr[i],i};
        }
        sort(nums.begin(),nums.end());
        vector<int>ans(n,0);

        int rank=0;
        int prev=INT_MIN;
        for(int i=0;i<n;i++)
        {
            int value=nums[i].first;
            int index=nums[i].second;
            
            if(value==prev)
            {
                ans[index]=rank;
                prev=value;
            }
            else
            {
                rank++;
                ans[index]=rank;
                prev=value;
            }
        }
        return ans;
    }
};
